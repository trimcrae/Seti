# Data caches and intermediate products (kept out of git; rebuilt by `make data`)
data/cache/
data/raw/
data/interim/
data/processed/
results/figures/*.pdf
results/figures/*.png
results/tables/*.parquet
results/tables/*.csv
!results/tables/.gitkeep
!results/figures/.gitkeep

# But DO keep the small committed offline sample
!data/sample/
!data/sample/**

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
venv/

# OS / editor
.DS_Store
*.swp

# LaTeX build artifacts (but DO keep the compiled manuscript main.pdf)
paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.pdf
!paper/main.pdf
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
